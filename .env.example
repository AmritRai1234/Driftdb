# ═══════════════════════════════════════════════════════════════
# DriftDB Environment Configuration
# Copy to .env and customize for your deployment
# ═══════════════════════════════════════════════════════════════

# Authentication token (REQUIRED for production)
# Used for both REST API and WebSocket authentication
# Generate one with: openssl rand -hex 32
DRIFT_TOKEN=change-me-in-production

# Port mapping (defaults work for most setups)
DRIFT_REST_PORT=9211
DRIFT_WS_PORT=9210
